{
  "name": "teacher-services-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:dashboard": "npm run dev --workspace=apps/dashboard",
